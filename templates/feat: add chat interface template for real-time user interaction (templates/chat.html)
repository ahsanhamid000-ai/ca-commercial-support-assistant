{% extends "base.html" %}

{% block content %}
{% set doc_title = document.file_name if document.file_name is defined and document.file_name else (document.filename if document.filename is defined and document.filename else "Uploaded Document") %}
{% set default_questions = [
    "What is the main purpose of this document?",
    "Summarize the important points.",
    "What framework is required?",
    "Are any deadlines mentioned?",
    "What action items are listed?",
    "Who is responsible for approval?"
] %}
{% set guided_questions = preset_questions if preset_questions is defined and preset_questions else default_questions %}

<style>
    .chat-shell {
        max-width: 900px;
        margin: 30px auto;
    }

    .chat-card {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        padding: 24px;
    }

    .chat-subtitle {
        color: #555;
        margin-top: 6px;
        margin-bottom: 18px;
    }

    .chat-history {
        max-height: 460px;
        overflow-y: auto;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        background: #fafafa;
        margin-bottom: 18px;
    }

    .message {
        margin-bottom: 12px;
        padding: 12px 14px;
        border-radius: 12px;
        line-height: 1.55;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .message.user {
        background: #e8eefc;
    }

    .message.assistant {
        background: #eef7ea;
    }

    .message-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
        flex-wrap: wrap;
    }

    .source-badge {
        display: inline-block;
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 999px;
        background: #203864;
        color: white;
    }

    .custom-box {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px;
        background: #fcfcfc;
        margin-bottom: 18px;
        display: none;
    }

    .custom-box.active {
        display: block;
    }

    .custom-box textarea,
    .custom-box select {
        width: 100%;
        padding: 10px 12px;
        margin-top: 8px;
        margin-bottom: 12px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 14px;
        box-sizing: border-box;
    }

    .action-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .primary-btn,
    .secondary-btn,
    .danger-btn,
    .prompt-btn {
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        cursor: pointer;
        font-size: 14px;
    }

    .primary-btn {
        background: #203864;
        color: white;
    }

    .secondary-btn {
        background: #e5e7eb;
        color: #111827;
    }

    .danger-btn {
        background: #b42318;
        color: white;
    }

    .primary-btn:disabled,
    .secondary-btn:disabled,
    .danger-btn:disabled,
    .prompt-btn:disabled {
        opacity: 0.65;
        cursor: not-allowed;
    }

    .prompt-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 10px;
        margin-top: 14px;
    }

    .prompt-btn {
        background: #f3f4f6;
        color: #111827;
        text-align: left;
        min-height: 58px;
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 9999;
    }

    .modal-overlay.show {
        display: flex;
    }

    .modal-card {
        width: 100%;
        max-width: 760px;
        background: white;
        border-radius: 14px;
        padding: 22px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.20);
    }

    .modal-card h3 {
        margin-top: 0;
    }

    .modal-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 18px;
    }

    .helper-text {
        color: #6b7280;
        font-size: 13px;
        margin-top: 4px;
    }

    .status-text {
        margin-top: 10px;
        font-size: 14px;
        color: #374151;
        display: none;
    }

    .status-text.show {
        display: block;
    }
</style>

<div class="chat-shell">
    <div class="chat-card">
        <h2>Ask Questions About: {{ doc_title }}</h2>
        <p class="chat-subtitle">
            Choose from guided popup prompts or ask a custom question.
        </p>

        <div class="chat-history" id="chatHistory">
            {% if not chat_history %}
                <div class="message assistant">
                    <div class="message-meta">
                        <strong>Assistant:</strong>
                    </div>
                    Please choose a question from the popup list.
                </div>
            {% endif %}

            {% for item in chat_history %}
                {% set user_q = item.user_question if item.user_question is defined else (item.question if item.question is defined else "") %}
                {% set bot_a = item.chatbot_answer if item.chatbot_answer is defined else (item.answer if item.answer is defined else "") %}
                {% set bot_source = item.source if item.source is defined else "" %}

                <div class="message user">
                    <div class="message-meta">
                        <strong>You:</strong>
                    </div>
                    {{ user_q }}
                </div>

                <div class="message assistant">
                    <div class="message-meta">
                        <strong>Assistant:</strong>
                        {% if bot_source %}
                            <span class="source-badge">{{ bot_source }}</span>
                        {% endif %}
                    </div>
                    {{ bot_a }}
                </div>
            {% endfor %}
        </div>

        <div id="customQuestionBox" class="custom-box">
            <label for="questionInput"><strong>Type your custom question</strong></label>
            <textarea id="questionInput" rows="4" placeholder="Type any question here..."></textarea>

            <label for="fallbackMode"><strong>Choose answer source</strong></label>
            <select id="fallbackMode">
                <option value="document_then_openai">Check document first, then use OpenAI</option>
                <option value="document_then_google">Check document first, then search Google</option>
                <option value="openai_only">Use OpenAI only</option>
                <option value="google_only">Use Google only</option>
            </select>

            <p class="helper-text">
                For custom questions, the app can answer from the uploaded document first or use OpenAI / Google.
            </p>

            <div class="action-row">
                <button type="button" class="primary-btn" id="submitCustomQuestionBtn">Ask Custom Question</button>
                <button type="button" class="secondary-btn" id="hideCustomBoxBtn">Cancel</button>
            </div>
        </div>

        <div class="action-row">
            <button type="button" class="primary-btn" id="openQuestionModalBtn">Choose from Question List</button>
            <button type="button" class="secondary-btn" id="showCustomBoxBtn">Ask a Custom Question</button>
            <button type="button" class="danger-btn" id="exitBtn">Exit</button>
        </div>

        <div class="status-text" id="statusText">Processing your question...</div>
    </div>
</div>

<div class="modal-overlay" id="questionModal">
    <div class="modal-card">
        <h3>Select a Question</h3>
        <p>Please pick one of the guided questions below.</p>

        <div class="prompt-grid">
            {% for q in guided_questions %}
                <button type="button" class="prompt-btn preset-question-btn" data-question="{{ q }}">{{ q }}</button>
            {% endfor %}
        </div>

        <div class="modal-actions">
            <button type="button" class="secondary-btn" id="openCustomFromModalBtn">Ask a Custom Question</button>
            <button type="button" class="danger-btn" id="modalExitBtn">Exit</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="nextStepModal">
    <div class="modal-card">
        <h3>What would you like to do next?</h3>
        <p>Please choose another question or exit the program.</p>

        <div class="modal-actions">
            <button type="button" class="primary-btn" id="askAnotherBtn">Select Another Question</button>
            <button type="button" class="secondary-btn" id="askCustomAfterAnswerBtn">Ask a Custom Question</button>
            <button type="button" class="danger-btn" id="nextStepExitBtn">Exit</button>
        </div>
    </div>
</div>

<script>
    window.CHAT_PAGE_STATE = {
        askUrl: window.location.pathname.replace("/chat/", "/ask/"),
        homeUrl: "{{ url_for('index') }}"
    };
</script>
<script src="{{ url_for('static', filename='js/main.js') }}"></script>
{% endblock %}
